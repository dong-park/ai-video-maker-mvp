# AI Video Maker MVP — 환경변수 예시
#
# 아무것도 채우지 않아도 동작합니다(권장: 로컬 개발):
#   - Provider: MockProvider (고정 샘플 MP4 반환)
#   - Storage : 로컬 파일 스토리지 (.storage/, /api/files 로 서빙)
# 아래 키를 채우면 자동으로 실제 fal.ai / S3·R2 연동으로 분기됩니다.

# ---- 공통 ----
# 자체 스토리지 공개 URL의 베이스. webhook 으로 provider 에 전달하거나
# 절대 URL 이 필요할 때 사용. 미설정 시 http://localhost:3000.
PUBLIC_BASE_URL=

# ---- AI Video Provider (fal.ai) ----
# FAL_KEY 가 있으면 실제 fal.ai 어댑터가 활성화됩니다. 없으면 Mock.
FAL_KEY=
# MVP 기본 모델 (9:16 + 5초 지원하는 image-to-video). 미설정 시 Kling v1.5 standard.
FAL_MODEL=

# ---- Object Storage (Cloudflare R2 / AWS S3) ----
# 아래 3개(S3_BUCKET, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY)가 모두 있으면
# 실제 S3/R2 스토리지가 활성화됩니다. 없으면 로컬 파일 스토리지.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
# R2 등 S3 호환 엔드포인트 (예: https://<account>.r2.cloudflarestorage.com)
S3_ENDPOINT=
# 결과 파일 공개 베이스 URL (CDN / R2 public 도메인)
S3_PUBLIC_BASE_URL=

# ---- 데이터베이스 (Postgres / Supabase) ----
# 운영 시 db/migrations/0001_init.sql 을 적용하세요.
# 로컬/테스트는 in-memory 폴백으로 동작하므로 미설정이어도 됩니다.
DATABASE_URL=

# ---- (선택) Mock 튜닝 ----
# Mock provider 가 succeeded 까지 필요한 폴링 횟수 (기본 2).
MOCK_POLLS_TO_COMPLETE=
